@model IEnumerable<FastBurger.Application.DTOs.ProcesoPreparacionDTO>

<h1>Procesos de Preparación</h1>

<table class="table">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Descripción</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var proceso in Model)
        {
            <tr>
                <td>@proceso.NombreProducto</td>
                <td>@proceso.Descripcion</td>
                <td>
                    <a asp-action="Detalle" asp-route-id="@proceso.IdProceso">Ver Detalle</a>
                </td>
            </tr>
        }
    </tbody>
</table>