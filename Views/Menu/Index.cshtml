@model IEnumerable<FastBurger.Application.DTOs.MenuDTO>

@{
    ViewData["Title"] = "Menús";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold" style="color:#3D2B1F;">📋 Listado de Menús</h1>
    <a asp-action="Disponible" class="btn btn-fb">Ver Menú Disponible</a>
</div>

<p class="text-muted mb-4">Lista de todos los menús registrados, ordenados por fecha de disponibilidad más reciente.</p>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var menu in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 card-fb">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title fw-bold mb-0" style="color:#3D2B1F;">@menu.Nombre</h5>
                        @if (menu.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(menu.Descripcion))
                    {
                        <p class="card-text text-muted small mt-1">@menu.Descripcion</p>
                    }
                </div>
                <div class="card-body pt-2">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="p-2 rounded" style="background:#FFF8F0;">
                                <small class="text-muted d-block">📅 Inicio</small>
                                <span class="fw-semibold">@(menu.FechaInicio?.ToString("dd/MM/yyyy") ?? "—")</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-2 rounded" style="background:#FFF8F0;">
                                <small class="text-muted d-block">📅 Fin</small>
                                <span class="fw-semibold">@(menu.FechaFin?.ToString("dd/MM/yyyy") ?? "—")</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="d-flex align-items-center mb-1">
                            <span class="me-2">🕐</span>
                            <span class="fw-semibold">@(menu.HoraInicio?.ToString(@"hh\:mm") ?? "—") — @(menu.HoraFin?.ToString(@"hh\:mm") ?? "—")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(menu.DiasSemana))
                        {
                            <div class="d-flex align-items-center">
                                <span class="me-2">📆</span>
                                <span class="fw-semibold">@menu.DiasSemana</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white border-0 pb-3">
                </div>
            </div>
        </div>
    }
</div>
