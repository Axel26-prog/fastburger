@model FastBurger.Application.DTOs.MenuDTO?

@{
    ViewData["Title"] = "Menú Disponible";
}

@if (Model == null)
{
    <div class="alert alert-warning text-center mt-4" role="alert">
        <h4 class="alert-heading">No hay menú disponible</h4>
        <p class="mb-0">@ViewBag.Mensaje</p>
    </div>
}
else
{
    <div class="text-center mb-5 mt-3">
        <h1 class="fw-bold display-5" style="color:#3D2B1F;">🍔 @Model.Nombre</h1>
        <p class="lead fst-italic text-muted">@Model.Descripcion</p>
        <div class="d-flex justify-content-center gap-4 flex-wrap">
            <span>📅 @(Model.FechaInicio?.ToString("dd/MM/yyyy") ?? "—") — @(Model.FechaFin?.ToString("dd/MM/yyyy") ?? "—")</span>
            <span>🕐 @(Model.HoraInicio?.ToString(@"hh\:mm") ?? "—") a @(Model.HoraFin?.ToString(@"hh\:mm") ?? "—")</span>
            @if (!string.IsNullOrEmpty(Model.DiasSemana))
            {
                <span>📆 @Model.DiasSemana</span>
            }
        </div>
    </div>

    @if (Model.Items.Any())
    {
        @foreach (var grupo in Model.Items.GroupBy(i => i.Categoria))
        {
            <div class="mb-5">
                <h3 class="fw-bold pb-2 mb-4" style="color:#E63946; border-bottom: 3px solid #F4A261;">@grupo.Key</h3>

                @{
                    var productos = grupo.Where(i => i.Tipo == "Producto");
                    var combos = grupo.Where(i => i.Tipo == "Combo");
                }

                @if (productos.Any())
                {
                    <h6 class="text-uppercase text-muted fw-bold mb-3">Productos</h6>
                    @foreach (var item in productos)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3 pb-2" style="border-bottom: 1px dashed #ddd;">
                            <div>
                                <h5 class="mb-0 fw-bold" style="color:#3D2B1F;">@item.Nombre</h5>
                            </div>
                            <span class="fw-bold fs-5" style="color:#E63946;">₡@item.Precio</span>
                        </div>
                    }
                }

                @if (combos.Any())
                {
                    <h6 class="text-uppercase text-muted fw-bold mb-3 mt-4">Combos</h6>
                    @foreach (var item in combos)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3 pb-2" style="border-bottom: 1px dashed #ddd;">
                            <div>
                                <h5 class="mb-0 fw-bold" style="color:#3D2B1F;">@item.Nombre</h5>
                            </div>
                            <span class="fw-bold fs-5" style="color:#E63946;">₡@item.Precio</span>
                        </div>
                    }
                }
            </div>
        }
    }
    else
    {
        <p class="text-muted text-center fs-5">Este menú no tiene items cargados.</p>
    }
}

<div class="text-center mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>
