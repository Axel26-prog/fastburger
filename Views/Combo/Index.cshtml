@model IEnumerable<FastBurger.Application.DTOs.ComboDTO>

@{
    ViewData["Title"] = "Combos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold" style="color:#3D2B1F;">Combos</h1>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var combo in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 card-fb">
                @if (!string.IsNullOrEmpty(combo.ImagenUrl))
                {
                    <img src="@combo.ImagenUrl" class="card-img-top" alt="@combo.Nombre" style="height:200px; object-fit:cover;" />
                }
                else
                {
                    <div class="card-img-top d-flex align-items-center justify-content-center" style="height:200px; background:#f0f0f0;">
                        <span class="text-muted">Sin imagen disponible</span>
                    </div>
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold" style="color:#3D2B1F;">@combo.Nombre</h5>
                    <span class="badge bg-secondary mb-2 align-self-start">@combo.NombreCategoria</span>
                    <p class="mb-1 text-muted"><small>🍟 @combo.Productos.Count productos</small></p>
                    <p class="card-text fs-4 fw-bold mt-auto" style="color:#E63946;">₡@combo.Precio</p>
                    <a asp-action="Detalle" asp-route-id="@combo.IdCombo" class="btn btn-fb w-100">Ver Detalle</a>
                </div>
            </div>
        </div>
    }
</div>
